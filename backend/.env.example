# ─────────────────────────────────────────────
# Prefracta-AI – Backend Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=8080

# Frontend origin allowed by CORS (e.g. https://prefracta-ai.vercel.app)
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/prefracta?retryWrites=true&w=majority

# JSON Web Token secret (any long random string)
JWT_SECRET=replace_with_a_long_random_secret

# OpenRouter API (https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-...

# Razorpay (test-mode keys – https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

# Execution mode: "demo" skips real Azure spin-up; "normal" runs full pipeline
EXECUTION_MODE=demo
